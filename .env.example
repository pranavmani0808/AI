# General App Settings
APP_NAME="AI Search Engine"
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL Configuration
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_search

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# SearXNG Configuration
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET_KEY=34293f0b2f3484c2f42a5a9c086d7cb0efb32e652a9261a9b20ad97ee899c75a

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
LLM_PROVIDER=gemini

# RAG Grounding Configurations
RAG_TOP_K=8
RAG_MIN_SCORE=0.35
RAG_MAX_CONTEXT_CHUNKS=6
RAG_MAX_CONTEXT_CHARS=18000

# Embedding Configuration
EMBEDDING_PROVIDER=local

